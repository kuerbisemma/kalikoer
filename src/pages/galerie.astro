---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../features/galerie/HeroSection.astro';
import GalerySection from '../features/galerie/GalerySection.astro';
import { getTranslations } from '../i18n';

const language = 'de' as const;
const t = getTranslations(language);
---

<BaseLayout
  title="Galerie – kalikoer Chor in Immenstadt"
  description="Galerie von kalikoer: Bilder von Konzerten, Auftritten und gemeinsamen Momenten des Chors."
  canonicalPath="/galerie"
  languageBasePath="/galerie"
  language={language}
  bodyClass="page-galerie"
  activePage="galerie"
  contactHref="index.html#kontakt"
>
  <HeroSection language={language} />
  <GalerySection language={language} />
</BaseLayout>
