---
import { getTranslations, type Language } from '../../i18n';

interface Props {
  language?: Language;
}

const { language = 'de' } = Astro.props;
const t = getTranslations(language);

const galleryImages = [
  { src: 'kalikoer_Konzert_2026.07.19_Erlöserkirche Immenstadt (3).jpeg', alt: 'Konzert' },
  { src: 'kalikoer-17.07.2026-blaichach (1).jpg', alt: 'Konzert' },
  { src: 'kalikoer_Konzert_2026.07.17_Blaichach (2).jpeg', alt: 'Konzert' },
  { src: 'kalikoer_gemeinsam_2026.07.02.JPEG', alt: 'Gemeinschaft' },
  { src: 'kalikoer_2026.07.04.jpg', alt: 'Auftritt' },
  { src: 'kalikoer_13.06.2026.JPEG', alt: 'Auftritt' },
  { src: 'archiv_konzert2025.jpg', alt: 'Konzert 2025' },
  { src: 'kalikoer_gemeinsam.jpg', alt: 'Gemeinschaft' }
];
---

<div class="gallery-section">
  <div class="gallery-container">
    <div class="masonry-grid">
      {galleryImages.map((image, index) => (
        <div class="masonry-item" style={`--item-index: ${index}`}>
          <img 
            src={`/images/${image.src}`} 
            alt={image.alt}
            class="gallery-image lightbox-trigger"
          />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .gallery-section {
    padding: 72px 40px 100px;
    background: var(--white);
  }

  .gallery-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .masonry-grid {
    column-count: 4;
    column-gap: 24px;
    column-rule: none;
  }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: 24px;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,.07);
    transition: transform .28s, box-shadow .28s;
    cursor: pointer;
  }

  .masonry-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0,0,0,.12);
  }

  .gallery-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: transform .4s ease;
  }

  .masonry-item:hover .gallery-image {
    transform: scale(1.04);
  }

  @media (max-width: 1200px) {
    .masonry-grid {
      column-count: 3;
      column-gap: 20px;
    }

    .masonry-item {
      margin-bottom: 20px;
    }
  }

  @media (max-width: 900px) {
    .masonry-grid {
      column-count: 2;
      column-gap: 16px;
    }

    .masonry-item {
      margin-bottom: 16px;
    }

    .gallery-section {
      padding: 60px 24px 80px;
    }
  }

  @media (max-width: 600px) {
    .masonry-grid {
      column-count: 1;
      column-gap: 12px;
    }

    .masonry-item {
      margin-bottom: 12px;
    }

    .gallery-section {
      padding: 40px 16px 60px;
    }
  }
</style>
