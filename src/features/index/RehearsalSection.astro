---
import { getTranslations, type Language } from '../../i18n';

interface Props {
  language?: Language;
}

const { language = 'de' } = Astro.props;
const t = getTranslations(language);
---

<section id="probe">
  <div class="container">
    <div class="probe-grid">
      <div class="conductor-text">
        <div class="section-tag">{t.index.rehearsal.tag}</div>
        <h2 class="section-heading">{t.index.rehearsal.title}</h2>
        <p class="probe-intro">{t.index.rehearsal.intro1}</p>
        <p class="probe-intro"><strong>{t.index.rehearsal.intro2}</strong></p>
        <p class="probe-intro-last">{t.index.rehearsal.intro3}</p>

        <div class="probe-time">{t.index.rehearsal.cardTime}</div>
        <ul class="probe-points">
          {t.index.rehearsal.points.map((point) => <li>{point}</li>)}
        </ul>
        <a href="#kontakt" class="probe-cta">{t.index.rehearsal.cta}</a>
      </div>
      <div>
        <img src="/images/kalikoer_probentag_2026-03.jpg" alt={t.index.rehearsal.imageAlt} class="probe-photo" />
      </div>
    </div>
  </div>
</section>

<style>
  #probe { background: var(--cream); }

  .probe-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .probe-intro { color: #555; margin-bottom: 16px; }
  .probe-intro-last { color: #555; }

  .probe-time {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--dark);
    margin: 20px 0 10px;
  }

  .probe-points {
    list-style: none;
    display: grid;
    gap: 8px;
    margin: 2px 0 20px;
    padding: 0;
    font-size: 0.98rem;
    line-height: 1.45;
    color: #555;
  }

  .probe-points li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .probe-points li::before {
    content: '✓';
    font-weight: 800;
    color: var(--teal);
    line-height: 1;
    margin-top: 4px;
    flex-shrink: 0;
  }

  .probe-cta {
    display: inline-block;
    margin-top: 4px;
    background: var(--teal);
    color: var(--white);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1px;
    padding: 14px 34px;
    border-radius: 40px;
    transition: background .2s, transform .2s;
    text-transform: uppercase;
  }

  .probe-cta:hover {
    background: #1a3d4d;
    transform: translateY(-2px);
  }

  .probe-photo {
    width: 100%;
    border-radius: 12px;
    display: block;
    object-fit: cover;
  }

  .probe-photo { width: 100%; border-radius: 12px; display: block; margin-bottom: 16px; object-fit: cover; }

  @media (max-width: 900px) {
    .probe-grid { grid-template-columns: 1fr; }

    .probe-cta {
      width: 100%;
      text-align: center;
    }

    .probe-photo {
      width: calc(100% + 48px);
      max-width: none;
      margin-left: -24px;
      margin-right: -24px;
      border-radius: 0;
    }
  }
</style>
