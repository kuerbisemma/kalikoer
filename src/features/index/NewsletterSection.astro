<section id="instagram">
  <div class="container">
    <div class="newsletter-content">
      <div class="section-tag">Newsletter</div>
      <h2 class="section-heading">Bleib auf dem Laufenden.</h2>
      <p>Mit unserem Newsletter verpasst du keine Konzerte, Termine oder Specials mehr. Du wirst maximal 3-4 mal im Jahr von uns hören, nicht öfter – versprochen 😉 </p>

      <form class="newsletter-form" id="newsletter-form">
        <div class="form-group">
          <input
            type="email"
            id="newsletter-email"
            name="EMAIL"
            autocomplete="email"
            placeholder="Gib hier deine E-Mail an."
            required
          />
        </div>

        <button type="submit" class="btn-submit">Anmelden</button>

        <p class="form-message" id="form-message" style="display: none;"></p>

        <p class="newsletter-privacy">
          Indem du das Formular absendest, erklärst du dich einverstanden, dass die von dir angegebenen persönlichen Informationen an Brevo übertragen werden gemäß der
          <a href="https://www.brevo.com/de/legal/privacypolicy/" target="_blank" rel="noopener">Datenschutzerklärung von Brevo.</a>
        </p>

        <input type="text" name="email_address_check" value="" class="input-hidden" tabindex="-1" autocomplete="off" />
      </form>
    </div>
  </div>
</section>

<style>
  #instagram {
    background: var(--white);
    padding-top: 90px;
    padding-bottom: 90px;
  }

  .newsletter-content p {
    color: #555;
    margin-bottom: 16px;
  }

  .newsletter-highlight {
    font-size: 1.1rem;
    color: #444;
    font-weight: 600;
    margin-bottom: 20px;
  }

  .newsletter-form {
    margin-top: 8px;
    width: 100%;
  }

  .newsletter-form form {
    width: 100%;
  }

  .form-group {
    margin-bottom: 22px;
  }

  label {
    display: block;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--dark);
    letter-spacing: .5px;
  }

  input[type=email] {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid #ddd;
    border-radius: 8px;
    font-size: 15px;
    font-family: inherit;
    background: var(--white);
    color: var(--text);
    transition: border-color .2s;
  }

  input[type=email]:focus {
    outline: none;
    border-color: var(--teal);
  }

  .btn-submit {
    width: 30%;
    min-width: 180px;
    text-align: center;
    background: var(--teal);
    color: var(--white);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1px;
    padding: 14px 40px;
    border: none;
    border-radius: 40px;
    cursor: pointer;
    transition: background .2s, transform .2s;
    text-transform: uppercase;
  }

  .btn-submit:hover {
    background: #1a3d4d;
    transform: translateY(-2px);
  }

  .newsletter-privacy {
    margin-top: 18px;
    font-size: 13px;
    color: #666;
    line-height: 1.6;
  }

  .newsletter-privacy a {
    color: var(--teal);
    text-decoration: underline;
  }

  .input-hidden {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  .form-message {
    margin-top: 12px;
    font-size: 14px;
    line-height: 1.5;
    padding: 12px;
    border-radius: 6px;
  }

  .form-message.success {
    color: #155724;
    background-color: #d4edda;
    border: 1px solid #c3e6cb;
  }

  .form-message.error {
    color: #721c24;
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
  }

  @media (max-width: 900px) {
    #instagram {
      padding-top: 64px;
      padding-bottom: 64px;
    }

    #instagram {
      padding-left: 12px;
      padding-right: 12px;
    }

    .btn-submit {
      width: 30%;
      min-width: 150px;
    }
  }
</style>

<script>
  // Newsletter Form Handler für DSGVO-Konformität
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const messageEl = document.getElementById('form-message') as HTMLElement;
  const submitBtn = form?.querySelector('.btn-submit') as HTMLButtonElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = (form.querySelector('#newsletter-email') as HTMLInputElement).value;
      const honeypot = (form.querySelector('[name="email_address_check"]') as HTMLInputElement).value;

      // Spam-Check: Honey Pot sollte leer sein
      if (honeypot) {
        console.log('Spam detected');
        return;
      }

      // Email-Validierung
      if (!email || !email.includes('@')) {
        showMessage('Bitte gib eine gültige E-Mail-Adresse ein.', 'error');
        return;
      }

      try {
        // Button deaktivieren während des Requests
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Wird versendet...';
        }

        // Anfrage an den lokalen API-Endpoint (kein CORS-Problem)
        const response = await fetch('/api/newsletter', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email }),
        });

        if (response.ok) {
          // Erfolgsmeldung anzeigen
          showMessage('Vielen Dank. Du erhältst in Kürze eine E-Mail.', 'success');
          form.reset();
        } else {
          showMessage('Es gab ein Problem beim Absenden. Bitte versuche es später erneut.', 'error');
        }
      } catch (error) {
        console.error('Newsletter subscription error:', error);
        showMessage('Es gab ein Problem beim Absenden. Bitte versuche es später erneut.', 'error');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Anmelden';
        }
      }
    });
  }

  function showMessage(text: string, type: 'success' | 'error') {
    if (messageEl) {
      messageEl.textContent = text;
      messageEl.className = `form-message ${type}`;
      messageEl.style.display = 'block';

      // Message nach 5 Sekunden ausblenden (bei Success)
      if (type === 'success') {
        setTimeout(() => {
          messageEl.style.display = 'none';
        }, 5000);
      }
    }
  }
</script>
