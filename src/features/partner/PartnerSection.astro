---
import { getTranslations, type Language } from '../../i18n';

interface Props {
  language?: Language;
}

const { language = 'de' } = Astro.props;
const t = getTranslations(language);

const partnerCards = [
  {
    href: 'https://www.ig-oma.de/',
    imageSrc: '/images/logo-igoma.png',
    imageAlt: 'Logo IG OMa e.V.'
  },
  {
    href: 'https://www.immenstadt-evangelisch.de/',
    imageSrc: '/images/logo-erloeserkirche-immenstadt.png',
    imageAlt: 'Logo Erlöserkirche Immenstadt'
  }
];
---

<div class="archive-section">
  <div class="year-group">
    <div class="year-label">{t.header.partner}</div>
    <div class="archive-grid">
      {partnerCards.map((card, index) => (
        <div class="archive-card logo">
          <a class="card-link" href={card.href} target="_blank" rel="noopener noreferrer">
            <div class="card-img">
              <img src={card.imageSrc} alt={card.imageAlt} class="lightbox-trigger" />
            </div>
          </a>
          <div class="card-body">
            <a class="card-link" href={card.href} target="_blank" rel="noopener noreferrer">
              <div class="card-title">{t.partner.cards[index].title}</div>
            </a>
            <p class="card-desc">{t.partner.cards[index].desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .archive-section {
    padding: 72px 40px 100px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .year-group { margin-bottom: 64px; }

  .year-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--slate);
    margin-bottom: 18px;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .archive-card {
    background: var(--white);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 20px rgba(0,0,0,.07);
    transition: transform .28s, box-shadow .28s;
  }

  .archive-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0,0,0,.12);
  }

  .archive-card.logo .card-img {
    aspect-ratio: 16/9;
    background: var(--white);
  }

  .card-img {
    overflow: hidden;
    flex-shrink: 0;
  }

  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 24px;
    display: block;
    transition: transform .4s ease;
  }

  .archive-card:hover .card-img img { transform: scale(1.04); }

  .card-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .card-link:hover .card-title {
    color: var(--teal);
  }

  .card-body {
    padding: 24px 26px 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.65;
    flex: 1;
  }

  @media (max-width: 900px) {
    .archive-section { padding-left: 24px; padding-right: 24px; }
    .archive-grid { grid-template-columns: 1fr 1fr; }

    .card-img {
      width: calc(100% + 48px);
      max-width: none;
      margin-left: -24px;
      margin-right: -24px;
      border-radius: 0;
    }
  }

  @media (max-width: 580px) {
    .archive-grid { grid-template-columns: 1fr; }
  }
</style>
